-- ESP (БЕЗ Visible Check)
-- ============================================================
local espActive = false
local espConnections = {}

function espLoop()
    while espActive do
        pcall(function()
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local head = plr.Character:FindFirstChild("Head")
                    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                    
                    if not head or not hum or hum.Health <= 0 then
                        pcall(function()
                            local hl = plr.Character:FindFirstChild("ESP_HL")
                            if hl then hl:Destroy() end
                        end)
                        if head then
                            local bb = head:FindFirstChild("ESP_BB")
                            if bb then bb:Destroy() end
                        end
                        continue
                    end
                    
                    local hl = plr.Character:FindFirstChild("ESP_HL")
                    if not hl then
                        hl = Instance.new("Highlight")
                        hl.Name = "ESP_HL"
                        hl.FillTransparency = 0.5
                        hl.OutlineTransparency = 0
                        hl.Parent = plr.Character
                    end
                    hl.Adornee = plr.Character
                    hl.FillColor = Settings.ESPColor
                    hl.OutlineColor = Settings.ESPColor
                    
                    local showInfo = Settings.ESPShowName or Settings.ESPShowHP or Settings.ESPShowDistance
                    local bb = head:FindFirstChild("ESP_BB")
                    
                    if showInfo then
                        if not bb then
                            bb = Instance.new("BillboardGui")
                            bb.Name = "ESP_BB"
                            bb.Size = UDim2.new(0, 150, 0, 50)
                            bb.StudsOffset = Vector3.new(0, 3, 0)
                            bb.AlwaysOnTop = true
                            bb.Parent = head
                            
                            local lb = Instance.new("TextLabel")
                            lb.Name = "ESP_Text"
                            lb.Size = UDim2.new(1, 0, 1, 0)
                            lb.BackgroundTransparency = 1
                            lb.TextColor3 = Color3.fromRGB(255,255,255)
                            lb.TextSize = 12
                            lb.Font = Enum.Font.GothamBold
                            lb.TextStrokeTransparency = 0.5
                            lb.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                            lb.Parent = bb
                        end
                        
                        local lb = bb:FindFirstChild("ESP_Text")
                        if lb then
                            local txt = ""
                            if Settings.ESPShowName then 
                                txt = txt .. plr.Name .. "\n" 
                            end
                            if Settings.ESPShowHP then 
                                txt = txt .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth) .. " HP\n" 
                            end
                            if Settings.ESPShowDistance and LocalPlayer.Character then
                                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                if root then 
                                    txt = txt .. math.floor((head.Position - root.Position).Magnitude) .. "m" 
                                end
                            end
                            lb.Text = txt
                        end
                    elseif bb then 
                        bb:Destroy() 
                    end
                end
            end
        end)
        task.wait(0.2)
    end
end

function enableESP() 
    espActive = true
    for _, conn in ipairs(espConnections) do
        pcall(function() conn:Disconnect() end)
    end
    espConnections = {}
    
    table.insert(espConnections, Players.PlayerRemoving:Connect(function(plr)
        pcall(function()
            if plr.Character then
                local hl = plr.Character:FindFirstChild("ESP_HL")
                if hl then hl:Destroy() end
                local head = plr.Character:FindFirstChild("Head")
                if head then
                    local bb = head:FindFirstChild("ESP_BB")
                    if bb then bb:Destroy() end
                end
            end
        end)
    end))
    
    task.spawn(espLoop) 
end

function disableESP()
    espActive = false
    for _, conn in ipairs(espConnections) do
        pcall(function() conn:Disconnect() end)
    end
    espConnections = {}
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            pcall(function()
                local hl = plr.Character:FindFirstChild("ESP_HL")
                if hl then hl:Destroy() end
            end)
            local head = plr.Character:FindFirstChild("Head")
            if head then
                local bb = head:FindFirstChild("ESP_BB")
                if bb then bb:Destroy() end
            end
        end
    end
end

