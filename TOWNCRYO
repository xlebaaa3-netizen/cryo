-- FOV Circle
local FOVCircle = nil
function updateFOVCircle()
    if FOVCircle then 
        pcall(function() FOVCircle:Remove() end)
        FOVCircle = nil 
    end
    if not (Settings.Aimbot and Settings.FOVCircle) then return end
    
    FOVCircle = Drawing.new("Circle")
    FOVCircle.Visible = true
    FOVCircle.Thickness = 1.5
    FOVCircle.Transparency = 0.7
    FOVCircle.ZIndex = 10
    FOVCircle.Filled = false
    FOVCircle.NumSides = 64
    
    local c
    c = RunService.RenderStepped:Connect(function()
        if not FOVCircle or not Settings.Aimbot then 
            if c then c:Disconnect() end 
            return 
        end
        local cam = workspace.CurrentCamera
        if cam then
            FOVCircle.Position = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
            local fovRad = math.rad(Settings.AimbotFOV / 2)
            local radius = math.tan(fovRad) * (cam.ViewportSize.Y / 2) / math.tan(math.rad(cam.FieldOfView / 2))
            FOVCircle.Radius = math.clamp(radius, 10, math.min(cam.ViewportSize.X, cam.ViewportSize.Y) / 2)
            FOVCircle.Color = Settings.FOVColor
        end
    end)
end

-- Functions
function setFullBright(v)
    Lighting.Brightness = v and 3 or 1
    Lighting.FogEnd = v and 99999 or 1000
    Lighting.OutdoorAmbient = v and Color3.fromRGB(255,255,255) or Color3.fromRGB(128,128,128)
    Lighting.GlobalShadows = not v
end

function setNoFog(v)
    Lighting.FogEnd = v and 99999 or 1000
end

