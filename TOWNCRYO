-- Trigger Bot
local triggerActive = false; local mouseHeld = false
function enableTriggerBot()
    triggerActive = true; task.spawn(function()
        while triggerActive do pcall(function()
            local cam = workspace.CurrentCamera
            if cam and LocalPlayer.Character then
                local ray = Ray.new(cam.CFrame.Position, cam.CFrame.LookVector*500)
                local hit = workspace:FindPartOnRay(ray, LocalPlayer.Character)
                local found = false
                if hit then local hum = hit.Parent:FindFirstChildOfClass("Humanoid") or (hit.Parent.Parent and hit.Parent.Parent:FindFirstChildOfClass("Humanoid"))
                    if hum and hum.Health > 0 and hum.Parent ~= LocalPlayer.Character then found = true end end
                if found and not mouseHeld then VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0); mouseHeld = true
                elseif not found and mouseHeld then VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0); mouseHeld = false end
            end
        end); task.wait(0.1) end
        if mouseHeld then VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0); mouseHeld = false end
    end)
end
function disableTriggerBot() triggerActive = false; if mouseHeld then VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0); mouseHeld = false end end

