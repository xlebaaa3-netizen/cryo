-- Wall Check
local function canSeeTarget(part)
    if not Settings.AimbotWallCheck then return true end
    local char = LocalPlayer.Character
    if not char then return true end
    local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    if not head then return true end
    
    local origin = head.Position
    local dir = (part.Position - origin).Unit
    local dist = (part.Position - origin).Magnitude
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local result = workspace:Raycast(origin, dir * dist, raycastParams)
    
    if result then
        return result.Instance:IsDescendantOf(part.Parent)
    end
    return true
end

-- Check if player is Passive
local function isPassive(plr)
    if not plr.Character then return false end
    
    local playerFolder = workspace:FindFirstChild(plr.Name)
    if playerFolder then
        local passive = playerFolder:FindFirstChild("Passive")
        if passive and passive:IsA("BoolValue") and passive.Value == true then
            return true
        end
    end
    
    local charPassive = plr.Character:FindFirstChild("Passive")
    if charPassive and charPassive:IsA("BoolValue") and charPassive.Value == true then
        return true
    end
    
    return false
end

-- Check if player is friend
local function isFriend(plr)
    if not Settings.AimbotIgnoreFriends then return false end
    return LocalPlayer:IsFriendsWith(plr.UserId)
end

-- Get target part
local function getTargetPart(char, partName)
    if partName == "Head" then 
        return char:FindFirstChild("Head")
    elseif partName == "UpperTorso" then 
        return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    elseif partName == "HumanoidRootPart" then 
        return char:FindFirstChild("HumanoidRootPart")
    end
    return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
end

-- Get valid targets
local function getValidTargets(partName)
    local targets = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            if Settings.AimbotIgnorePassive and isPassive(plr) then
                continue
            end
            
            if isFriend(plr) then
                continue
            end
            
            local part = getTargetPart(plr.Character, partName)
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if part and hum and hum.Health > 0 then
                table.insert(targets, {part = part, hum = hum, player = plr})
            end
        end
    end
    return targets
end

-- Smooth aim
local currentAimTarget = nil
local function smoothAim(cam, targetPos, smoothAmount)
    local camPos = cam.CFrame.Position
    local currentLook = cam.CFrame.LookVector
    local targetLook = (targetPos - camPos).Unit
    
    local t = smoothAmount / 100
    t = math.clamp(t, 0.01, 1)
    
    local smoothedLook = currentLook:Lerp(targetLook, t)
    cam.CFrame = CFrame.new(camPos, camPos + smoothedLook)
end

-- Aimbot
local aimbotActive = false
local aimbotConn = nil

function enableAimbot()
    aimbotActive = true
    if aimbotConn then aimbotConn:Disconnect() end
    
    aimbotConn = RunService.RenderStepped:Connect(function()
        if not aimbotActive then return end
        pcall(function()
            local cam = workspace.CurrentCamera
            if not cam or not LocalPlayer.Character then return end
            
            local camPos = cam.CFrame.Position
            local camDir = cam.CFrame.LookVector
            local targets = getValidTargets(Settings.AimbotPart)
            
            if #targets == 0 then 
                currentAimTarget = nil
                return 
            end
            
            local best = nil
            local bestValue = math.huge
            
            for _, t in ipairs(targets) do
                if not canSeeTarget(t.part) then continue end
                
                local toTarget = (t.part.Position - camPos).Unit
                local angle = math.deg(math.acos(math.clamp(camDir:Dot(toTarget), -1, 1)))
                
                if angle >= Settings.AimbotFOV / 2 then continue end                
                local value
                if Settings.AimbotPriority == "Distance" then
                    value = (t.part.Position - camPos).Magnitude
                elseif Settings.AimbotPriority == "FOV" then
                    value = angle
                elseif Settings.AimbotPriority == "Health" then
                    value = t.hum.Health
                end
                
                if value < bestValue then
                    bestValue = value
                    best = t
                end
            end
            
            if best then 
                currentAimTarget = best.player
                if Settings.AimbotSmooth then
                    smoothAim(cam, best.part.Position, Settings.AimbotSmoothAmount)
                else
                    cam.CFrame = CFrame.new(camPos, best.part.Position)
                end
            else
                currentAimTarget = nil
            end
        end)
    end)
end

function disableAimbot()
    aimbotActive = false
    currentAimTarget = nil
    if aimbotConn then 
        aimbotConn:Disconnect()
        aimbotConn = nil 
    end
end

