-- // FOV Circle
local FOVCircle = nil

function updateFOVCircle()
    if FOVCircle then 
        pcall(function() FOVCircle:Remove() end) 
        FOVCircle = nil 
    end
    
    if not (Settings.Aimbot and Settings.FOVCircle) then 
        return 
    end
    
    FOVCircle = Drawing.new("Circle")
    FOVCircle.Visible = true
    FOVCircle.Thickness = 1.5
    FOVCircle.Transparency = 0.7
    FOVCircle.ZIndex = 10
    
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not FOVCircle or not Settings.Aimbot then 
            if connection then 
                connection:Disconnect() 
            end 
            return 
        end
        
        local camera = workspace.CurrentCamera
        if camera then
            FOVCircle.Position = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
            FOVCircle.Radius = Settings.AimbotFOV * 3
            FOVCircle.Color = Settings.FOVColor
        end
    end)
end

-- // Full Bright
function setFullBright(state)
    Lighting.Brightness = state and 3 or 1
    Lighting.FogEnd = state and 99999 or 1000
    Lighting.OutdoorAmbient = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(128, 128, 128)
    Lighting.GlobalShadows = not state
end

-- // No Fog
function setNoFog(state) 
    Lighting.FogEnd = state and 99999 or 1000 
end

-- // ESP
local espEnabled = false

function espUpdateLoop()
    while espEnabled do
        pcall(function()
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local head = player.Character:FindFirstChild("Head")
                    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                    
                    if head and humanoid and humanoid.Health > 0 then
                        local highlight = player.Character:FindFirstChild("ESP_HL")
                        if not highlight then
                            highlight = Instance.new("Highlight")
                            highlight.Name = "ESP_HL"
                            highlight.FillTransparency = 0.5
                            highlight.Parent = player.Character
                        end
                        highlight.Adornee = player.Character
                        highlight.FillColor = Settings.ESPColor
                        
                        if Settings.ESPShowName or Settings.ESPShowHP or Settings.ESPShowDistance then
                            local billboard = head:FindFirstChild("ESP_BB")
                            if not billboard then
                                billboard = Instance.new("BillboardGui")
                                billboard.Name = "ESP_BB"
                                billboard.Size = UDim2.new(0, 130, 0, 20)
                                billboard.StudsOffset = Vector3.new(0, 2.5, 0)
                                billboard.AlwaysOnTop = true
                                billboard.Parent = head
                                
                                local label = Instance.new("TextLabel")
                                label.Size = UDim2.new(1, 0, 0, 20)
                                label.BackgroundTransparency = 1
                                label.TextColor3 = Color3.fromRGB(255, 255, 255)
                                label.TextSize = 10
                                label.Font = Enum.Font.GothamBold
                                label.Parent = billboard
                            end
                            
                            local label = billboard:FindFirstChild("TextLabel")
                            if label then
                                local infoText = ""
                                if Settings.ESPShowName then 
                                    infoText = infoText .. player.Name .. " " 
                                end
                                if Settings.ESPShowHP then 
                                    infoText = infoText .. math.floor(humanoid.Health) .. "HP " 
                                end
                                if Settings.ESPShowDistance and LocalPlayer.Character then
                                    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                    if root then 
                                        infoText = infoText .. math.floor((head.Position - root.Position).Magnitude) .. "m" 
                                    end
                                end
                                label.Text = infoText
                            end
                        else
                            local billboard = head:FindFirstChild("ESP_BB")
                            if billboard then 
                                billboard:Destroy() 
                            end
                        end
                    end
                end
            end
        end)
        task.wait(0.3)
    end
end

function enableESP() 
    espEnabled = true
    task.spawn(espUpdateLoop) 
end

function disableESP()
    espEnabled = false
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character then
            pcall(function()
                local highlight = player.Character:FindFirstChild("ESP_HL")
                if highlight then 
                    highlight:Destroy() 
                end
            end)
            local head = player.Character:FindFirstChild("Head")
            if head then
                local billboard = head:FindFirstChild("ESP_BB")
                if billboard then 
                    billboard:Destroy() 
                end
            end
        end
    end
end

-- // No Recoil
local recoilEnabled = false

function setNoRecoil(state)
    if state then
        recoilEnabled = true
        task.spawn(function()
            while recoilEnabled do
                pcall(function()
                    local recoil = LocalPlayer:FindFirstChild("Recoil")
                    if recoil then
                        for _, child in ipairs(recoil:GetChildren()) do
                            if child:IsA("CFrameValue") then 
                                child.Value = CFrame.new()
                            elseif child:IsA("NumberValue") then 
                                child.Value = 0 
                            end
                        end
                    end
                end)
                task.wait()
            end
        end)
    else
        recoilEnabled = false
    end
end

-- // No Sway
local swayEnabled = false

function setNoSway(state)
    if state then
        swayEnabled = true
        task.spawn(function()
            while swayEnabled do
                pcall(function()
                    local character = LocalPlayer.Character
                    if character then
                        local gunAim = character:FindFirstChild("GUNAIMVALUE")
                        if gunAim then
                            for _, child in ipairs(gunAim:GetChildren()) do
                                if child:IsA("NumberValue") then 
                                    child.Value = 0
                                elseif child.Name == "IsAimed" then 
                                    child.Value = false 
                                end
                            end
                        end
                    end
                end)
                task.wait()
            end
        end)
    else
        swayEnabled = false
    end
end

-- // Trigger Bot
local triggerEnabled = false
local mouseHeld = false

function enableTriggerBot()
    triggerEnabled = true
    task.spawn(function()
        while triggerEnabled do
            pcall(function()
                local camera = workspace.CurrentCamera
                if camera and LocalPlayer.Character then
                    local ray = Ray.new(camera.CFrame.Position, camera.CFrame.LookVector * 500)
                    local hitPart = workspace:FindPartOnRay(ray, LocalPlayer.Character)
                    local targetFound = false
                    
                    if hitPart then
                        local humanoid = hitPart.Parent:FindFirstChildOfClass("Humanoid") 
                            or (hitPart.Parent.Parent and hitPart.Parent.Parent:FindFirstChildOfClass("Humanoid"))
                        if humanoid and humanoid.Health > 0 and humanoid.Parent ~= LocalPlayer.Character then
                            targetFound = true
                        end
                    end
                    
                    if targetFound and not mouseHeld then
                        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                        mouseHeld = true
                    elseif not targetFound and mouseHeld then
                        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                        mouseHeld = false
                    end
                end
            end)
            task.wait(0.1)
        end
        
        if mouseHeld then
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
            mouseHeld = false
        end
    end)
end

function disableTriggerBot()
    triggerEnabled = false
    if mouseHeld then
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        mouseHeld = false
    end
end

