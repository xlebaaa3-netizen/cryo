-- FOV Circle
local FOVCircle = nil
function updateFOVCircle()
    if FOVCircle then pcall(function() FOVCircle:Remove() end); FOVCircle = nil end
    if not (Settings.Aimbot and Settings.FOVCircle) then return end
    FOVCircle = Drawing.new("Circle"); FOVCircle.Visible = true; FOVCircle.Thickness = 1.5; FOVCircle.Transparency = 0.7; FOVCircle.ZIndex = 10
    local c; c = RunService.RenderStepped:Connect(function()
        if not FOVCircle or not Settings.Aimbot then if c then c:Disconnect() end return end
        local cam = workspace.CurrentCamera
        if cam then FOVCircle.Position = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2); FOVCircle.Radius = Settings.AimbotFOV*3; FOVCircle.Color = Settings.FOVColor end
    end)
end

-- Functions
function setFullBright(v) Lighting.Brightness = v and 3 or 1; Lighting.FogEnd = v and 99999 or 1000; Lighting.OutdoorAmbient = v and Color3.fromRGB(255,255,255) or Color3.fromRGB(128,128,128); Lighting.GlobalShadows = not v end
function setNoFog(v) Lighting.FogEnd = v and 99999 or 1000 end

-- ESP
local espActive = false
function espLoop()
    while espActive do pcall(function()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local head = plr.Character:FindFirstChild("Head")
                local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                if head and hum and hum.Health > 0 then
                    local hl = plr.Character:FindFirstChild("ESP_HL")
                    if not hl then hl = Instance.new("Highlight"); hl.Name = "ESP_HL"; hl.FillTransparency = 0.5; hl.Parent = plr.Character end
                    hl.Adornee = plr.Character; hl.FillColor = Settings.ESPColor
                    local showInfo = Settings.ESPShowName or Settings.ESPShowHP or Settings.ESPShowDistance
                    local bb = head:FindFirstChild("ESP_BB")
                    if showInfo then
                        if not bb then bb = Instance.new("BillboardGui"); bb.Name = "ESP_BB"; bb.Size = UDim2.new(0,130,0,20); bb.StudsOffset = Vector3.new(0,2.5,0); bb.AlwaysOnTop = true; bb.Parent = head
                            local lb = Instance.new("TextLabel",bb); lb.Size = UDim2.new(1,0,0,20); lb.BackgroundTransparency = 1; lb.TextColor3 = Color3.fromRGB(255,255,255); lb.TextSize = 10; lb.Font = Enum.Font.GothamBold end
                        local lb = bb:FindFirstChild("TextLabel")
                        if lb then
                            local txt = ""
                            if Settings.ESPShowName then txt = txt .. plr.Name .. " " end
                            if Settings.ESPShowHP then txt = txt .. math.floor(hum.Health) .. "HP " end
                            if Settings.ESPShowDistance and LocalPlayer.Character then
                                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                if root then txt = txt .. math.floor((head.Position - root.Position).Magnitude) .. "m" end
                            end
                            lb.Text = txt
                        end
                    elseif bb then bb:Destroy() end
                end
            end
        end
    end); task.wait(0.3) end
end
function enableESP() espActive = true; task.spawn(espLoop) end
function disableESP()
    espActive = false
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            pcall(function() local hl = plr.Character:FindFirstChild("ESP_HL"); if hl then hl:Destroy() end end)
            local head = plr.Character:FindFirstChild("Head")
            if head then local bb = head:FindFirstChild("ESP_BB"); if bb then bb:Destroy() end end
        end
    end
end

