-- NO RECOIL (v5 — полная поддержка прицелов Sights, БЕЗ GOTO)
-- ============================================================
local noRecoilActive = false
local noRecoilConnections = {}

function setNoRecoil(v)
    if not v then 
        noRecoilActive = false
        for _, conn in ipairs(noRecoilConnections) do
            pcall(function() conn:Disconnect() end)
        end
        noRecoilConnections = {}
        return 
    end
    noRecoilActive = true
    
    -- Метод 1: Обнуляем Recoil Values каждый кадр
    local conn1 = RunService.Heartbeat:Connect(function()
        if not noRecoilActive then return end
        pcall(function()
            local recoil = LocalPlayer:FindFirstChild("Recoil")
            if recoil then
                for _, child in ipairs(recoil:GetDescendants()) do
                    if child:IsA("CFrameValue") then
                        child.Value = CFrame.new()
                    elseif child:IsA("NumberValue") then
                        child.Value = 0
                    end
                end
            end
        end)
    end)
    table.insert(noRecoilConnections, conn1)
    
    -- Метод 2: Обнуляем GUNAIMVALUE
    local conn2 = RunService.Heartbeat:Connect(function()
        if not noRecoilActive then return end
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            local gav = char:FindFirstChild("GUNAIMVALUE")
            if gav then
                for _, c in ipairs(gav:GetChildren()) do
                    if c:IsA("NumberValue") then
                        c.Value = 0
                    end
                end
                if gav:IsA("NumberValue") then
                    gav.Value = 0
                end
            end
        end)
    end)
    table.insert(noRecoilConnections, conn2)
    
    -- Метод 3: Обнуляем Stats ВСЕХ прицелов (Sights)
    local function processAttachments(tool)
        if not tool:IsA("Tool") then return end
        
        local attachFolder = tool:FindFirstChild("AttachmentFolder")
        if not attachFolder then return end
        
        for _, attachment in ipairs(attachFolder:GetChildren()) do
            -- Проверяем, является ли это прицелом (Sights)
            local isAttach = attachment:FindFirstChild("IsAttachment")
            if isAttach and isAttach:IsA("StringValue") and isAttach.Value == "Sights" then
                local stats = attachment:FindFirstChild("Stats")
                if stats then
                    local recoilStats = {
                        "GunRecoil",
                        "GunRecoilX", 
                        "GunRecoilAimed",
                        "RecoilAngle",
                        "RecoilSpread",
                        "RecoilStrength",
                        "AimSway",
                        "AimSpeed",
                        "AimScatterMultiplyer"
                    }
                    
                    for _, statName in ipairs(recoilStats) do
                        local stat = stats:FindFirstChild(statName)
                        if stat and stat:IsA("NumberValue") then
                            stat.Value = 0
                        end
                    end
                end
            end
        end
    end
    
    local conn3 = RunService.Heartbeat:Connect(function()
        if not noRecoilActive then return end
        pcall(function()
            -- Обрабатываем все оружие в бекпаке
            for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
                processAttachments(tool)
            end
            
            -- Обрабатываем оружие в руках
            local char = LocalPlayer.Character
            if char then
                for _, tool in ipairs(char:GetChildren()) do
                    processAttachments(tool)
                end
            end
        end)
    end)
    table.insert(noRecoilConnections, conn3)
    
    -- Метод 4: Блокируем CameraShake
    local conn4 = RunService.RenderStepped:Connect(function()
        if not noRecoilActive then return end
        pcall(function()
            if not Settings.Aimbot then
                local recoil = LocalPlayer:FindFirstChild("Recoil")
                if recoil then
                    local cr = recoil:FindFirstChild("CurrentRecoil")
                    local cr2 = recoil:FindFirstChild("CurrentRecoil2")
                    local cr3 = recoil:FindFirstChild("CurrentRecoil3")
                    
                    if cr and cr:IsA("CFrameValue") and cr.Value ~= CFrame.new() then
                        cr.Value = CFrame.new()
                    end
                    if cr2 and cr2:IsA("CFrameValue") and cr2.Value ~= CFrame.new() then
                        cr2.Value = CFrame.new()
                    end
                    if cr3 and cr3:IsA("NumberValue") and cr3.Value ~= 0 then
                        cr3.Value = 0
                    end
                end
            end
        end)
    end)
    table.insert(noRecoilConnections, conn4)
    
    -- Метод 5: Ускоряем анимации отдачи
    local conn5 = RunService.Heartbeat:Connect(function()
        if not noRecoilActive then return end
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if not humanoid then return end
            
            for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
                if not track.Animation then continue end
                local animName = track.Animation.Name or ""
                if animName:lower():find("fire") or 
                   animName:lower():find("recoil") or
                   animName:lower():find("aim") then
                    track:AdjustSpeed(999)
                end
            end
        end)
    end)
    table.insert(noRecoilConnections, conn5)
    
    -- Метод 6: Создаём фейковые Value в оружии
    local conn6 = RunService.Heartbeat:Connect(function()
        if not noRecoilActive then return end
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            for _, tool in ipairs(char:GetChildren()) do
                if not tool:IsA("Tool") then continue end
                
                local fakeStats = {
                    GunRecoil = 0,
                    GunRecoilX = 0,
                    RecoilAngle = 0,
                    RecoilSpread = 0,
                    RecoilStrength = 0,
                    AimSway = 0
                }
                
                for statName, statValue in pairs(fakeStats) do
                    local existing = tool:FindFirstChild(statName)
                    if not existing then
                        local val = Instance.new("NumberValue")
                        val.Name = statName
                        val.Value = statValue
                        val.Parent = tool
                    else
                        existing.Value = statValue
                    end
                end
            end
        end)
    end)
    table.insert(noRecoilConnections, conn6)
    
    -- Метод 7: Рекурсивный поиск ВСЕХ прицелов Sights
    local conn7 = RunService.Heartbeat:Connect(function()
        if not noRecoilActive then return end
        pcall(function()
            local function scanForSights(parent)
                if not parent then return end
                for _, child in ipairs(parent:GetChildren()) do
                    -- Ищем AttachmentFolder
                    if child:IsA("Folder") and child.Name == "AttachmentFolder" then
                        for _, attach in ipairs(child:GetChildren()) do
                            local isAttach = attach:FindFirstChild("IsAttachment")
                            if isAttach and isAttach:IsA("StringValue") and isAttach.Value == "Sights" then
                                local stats = attach:FindFirstChild("Stats")
                                if stats then
                                    for _, stat in ipairs(stats:GetChildren()) do
                                        if stat:IsA("NumberValue") then
                                            local name = stat.Name
                                            if name:find("Recoil") or 
                                               name:find("Sway") or 
                                               name:find("Spread") or
                                               name:find("Scatter") then
                                                stat.Value = 0
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                    -- Рекурсивно сканируем вложенные объекты
                    scanForSights(child)
                end
            end
            
            scanForSights(LocalPlayer.Backpack)
            
            local char = LocalPlayer.Character
            if char then
                scanForSights(char)
            end
        end)
    end)
    table.insert(noRecoilConnections, conn7)
end

-- No Sway
local swayActive = false
function setNoSway(v)
    if not v then
        swayActive = false
        return
    end
    swayActive = true
    task.spawn(function()
        while swayActive do
            pcall(function()
                local char = LocalPlayer.Character
                if char then
                    local gav = char:FindFirstChild("GUNAIMVALUE") or char:FindFirstChild("GunAimValue")
                    if gav then
                        for _, c in ipairs(gav:GetChildren()) do
                            if c:IsA("NumberValue") then 
                                c.Value = 0
                            elseif c:IsA("BoolValue") and c.Name:lower():find("aim") then 
                                c.Value = false 
                            end
                        end
                    end
                    
                    for _, obj in ipairs(char:GetDescendants()) do
                        if obj.Name:lower():find("sway") and obj:IsA("NumberValue") then
                            obj.Value = 0
                        end
                    end
                end
            end)
            task.wait()
        end
    end)
end

-- Trigger Bot
local triggerActive = false
local triggerConn = nil

function enableTriggerBot()
    triggerActive = true
    triggerConn = RunService.RenderStepped:Connect(function()
        if not triggerActive then return end
        pcall(function()
            local cam = workspace.CurrentCamera
            if not cam or not LocalPlayer.Character then return end
            
            local ray = Ray.new(cam.CFrame.Position, cam.CFrame.LookVector * 1000)
            local hit, pos = workspace:FindPartOnRay(ray, LocalPlayer.Character)
            
            local found = false
            if hit then
                local hum = hit.Parent:FindFirstChildOfClass("Humanoid") 
                    or (hit.Parent.Parent and hit.Parent.Parent:FindFirstChildOfClass("Humanoid"))
                if hum and hum.Health > 0 and hum.Parent ~= LocalPlayer.Character then 
                    found = true 
                end
            end
            
            if found then
                mouse1press()
                task.wait(0.05)
                mouse1release()
            end
        end)
    end)
end

function disableTriggerBot()
    triggerActive = false
    if triggerConn then
        triggerConn:Disconnect()
        triggerConn = nil
    end
end

-- Infinite Ammo
local infAmmoActive = false
function enableInfiniteAmmo()
    infAmmoActive = true
    task.spawn(function()
        while infAmmoActive do
            pcall(function()
                local char = LocalPlayer.Character
                if char then
                    for _, tool in ipairs(char:GetChildren()) do
                        if tool:IsA("Tool") then
                            local gs = tool:FindFirstChild("GunScript") 
                                or tool:FindFirstChild("Gun") 
                                or tool:FindFirstChild("WeaponScript")
                            
                            if gs then
                                local ca = gs:FindFirstChild("ClientAmmo") or gs:FindFirstChild("Ammo") or gs:FindFirstChild("CurrentAmmo")
                                local maxAmmo = gs:FindFirstChild("MaxAmmo") or gs:FindFirstChild("Max") or gs:FindFirstChild("ClipSize")
                                
                                if ca then 
                                    ca.Value = maxAmmo and maxAmmo.Value or 30 
                                end
                            end
                            
                            local toolAmmo = tool:FindFirstChild("Ammo") or tool:FindFirstChild("ClientAmmo")
                            local toolMax = tool:FindFirstChild("MaxAmmo") or tool:FindFirstChild("MaxAmmo")
                            if toolAmmo and toolMax then
                                toolAmmo.Value = toolMax.Value
                            end
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end

function disableInfiniteAmmo() 
    infAmmoActive = false 
end

-- Instant Reload
local instantReloadActive = false
function setInstantReload(v)
    if not v then 
        instantReloadActive = false
        return 
    end
    instantReloadActive = true
    task.spawn(function()
        while instantReloadActive do
            pcall(function()
                local char = LocalPlayer.Character
                if not char then return end
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if not humanoid then return end
                
                for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
                    local animName = track.Animation and track.Animation.Name or ""
                    if animName:lower():find("reload") 
                        or animName:lower():find("bolt") 
                        or animName:lower():find("cock") then
                        track:AdjustSpeed(10)
                    end
                end
                
                for _, tool in ipairs(char:GetChildren()) do
                    if tool:IsA("Tool") then
                        local gs = tool:FindFirstChild("GunScript") or tool:FindFirstChild("Gun")
                        if gs then
                            local clientAmmo = gs:FindFirstChild("ClientAmmo") or gs:FindFirstChild("Ammo")
                            local maxAmmo = gs:FindFirstChild("MaxAmmo") or gs:FindFirstChild("Max")
                            if clientAmmo and maxAmmo and clientAmmo.Value <= 0 then
                                clientAmmo.Value = maxAmmo.Value
                            end
                        end
                    end
                end
            end)
            task.wait(0.05)
        end
    end)
end

-- No Spread
local noSpreadActive = false
function setNoSpread(v)
    if not v then 
        noSpreadActive = false
        return 
    end
    noSpreadActive = true
    task.spawn(function()
        while noSpreadActive do
            pcall(function()
                local char = LocalPlayer.Character
                if not char then return end
                
                for _, tool in ipairs(char:GetChildren()) do
                    if tool:IsA("Tool") then
                        local gs = tool:FindFirstChild("GunScript") or tool:FindFirstChild("Gun")
                        if gs then
                            local scatter = gs:FindFirstChild("scatter") 
                                or gs:FindFirstChild("Spread") 
                                or gs:FindFirstChild("BulletSpread")
                            
                            if scatter and scatter:IsA("NumberValue") then 
                                scatter.Value = 0 
                            end
                            
                            local aimScatter = gs:FindFirstChild("AimScatterMultiplyer") 
                                or gs:FindFirstChild("AimSpread")
                            
                            if aimScatter and aimScatter:IsA("NumberValue") then 
                                aimScatter.Value = 0 
                            end
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end

