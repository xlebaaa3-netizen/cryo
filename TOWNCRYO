-- FOV Circle
local FOVCircle = nil
function updateFOVCircle()
    if FOVCircle then pcall(function() FOVCircle:Remove() end); FOVCircle = nil end
    if not (Settings.Aimbot and Settings.FOVCircle) then return end
    FOVCircle = Drawing.new("Circle")
    FOVCircle.Visible = true
    FOVCircle.Thickness = 1.5
    FOVCircle.Transparency = 0.7
    FOVCircle.ZIndex = 10
    local c
    c = RunService.RenderStepped:Connect(function()
        if not FOVCircle or not Settings.Aimbot then if c then c:Disconnect() end return end
        local cam = workspace.CurrentCamera
        if cam then
            FOVCircle.Position = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
            FOVCircle.Radius = Settings.AimbotFOV * 3
            FOVCircle.Color = Settings.FOVColor
        end
    end)
end

-- Functions
function setFullBright(v)
    Lighting.Brightness = v and 3 or 1
    Lighting.FogEnd = v and 99999 or 1000
    Lighting.OutdoorAmbient = v and Color3.fromRGB(255,255,255) or Color3.fromRGB(128,128,128)
    Lighting.GlobalShadows = not v
end

function setNoFog(v)
    Lighting.FogEnd = v and 99999 or 1000
end

-- ESP
local espActive = false
function espLoop()
    while espActive do
        pcall(function()
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local head = plr.Character:FindFirstChild("Head")
                    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                    if head and hum and hum.Health > 0 then
                        local hl = plr.Character:FindFirstChild("ESP_HL")
                        if not hl then
                            hl = Instance.new("Highlight")
                            hl.Name = "ESP_HL"
                            hl.FillTransparency = 0.5
                            hl.Parent = plr.Character
                        end
                        hl.Adornee = plr.Character
                        hl.FillColor = Settings.ESPColor
                        local showInfo = Settings.ESPShowName or Settings.ESPShowHP or Settings.ESPShowDistance
                        local bb = head:FindFirstChild("ESP_BB")
                        if showInfo then
                            if not bb then
                                bb = Instance.new("BillboardGui")
                                bb.Name = "ESP_BB"
                                bb.Size = UDim2.new(0,130,0,20)
                                bb.StudsOffset = Vector3.new(0,2.5,0)
                                bb.AlwaysOnTop = true
                                bb.Parent = head
                                local lb = Instance.new("TextLabel", bb)
                                lb.Size = UDim2.new(1,0,0,20)
                                lb.BackgroundTransparency = 1
                                lb.TextColor3 = Color3.fromRGB(255,255,255)
                                lb.TextSize = 10
                                lb.Font = Enum.Font.GothamBold
                            end
                            local lb = bb:FindFirstChild("TextLabel")
                            if lb then
                                local txt = ""
                                if Settings.ESPShowName then txt = txt .. plr.Name .. " " end
                                if Settings.ESPShowHP then txt = txt .. math.floor(hum.Health) .. "HP " end
                                if Settings.ESPShowDistance and LocalPlayer.Character then
                                    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                    if root then txt = txt .. math.floor((head.Position - root.Position).Magnitude) .. "m" end
                                end
                                lb.Text = txt
                            end
                        elseif bb then bb:Destroy() end
                    end
                end
            end
        end)
        task.wait(0.3)
    end
end

function enableESP() espActive = true; task.spawn(espLoop) end
function disableESP()
    espActive = false
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            pcall(function()
                local hl = plr.Character:FindFirstChild("ESP_HL")
                if hl then hl:Destroy() end
            end)
            local head = plr.Character:FindFirstChild("Head")
            if head then
                local bb = head:FindFirstChild("ESP_BB")
                if bb then bb:Destroy() end
            end
        end
    end
end

-- No Recoil
local noRecoilActive = false
function setNoRecoil(v)
    if not v then noRecoilActive = false; return end
    noRecoilActive = true
    task.spawn(function()
        while noRecoilActive do
            pcall(function()
                local recoil = LocalPlayer:FindFirstChild("Recoil")
                if recoil then
                    local currentRecoil = recoil:FindFirstChild("CurrentRecoil")
                    if currentRecoil then currentRecoil.Value = CFrame.new() end
                    local recoil2 = recoil:FindFirstChild("Recoil2")
                    if recoil2 then recoil2.Value = 0 end
                    local currentRecoil3 = recoil:FindFirstChild("CurrentRecoil3")
                    if currentRecoil3 then currentRecoil3.Value = 0 end
                    local currentRecoil2 = recoil:FindFirstChild("CurrentRecoil2")
                    if currentRecoil2 then currentRecoil2.Value = CFrame.new() end
                end
                local gunAim = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("GUNAIMVALUE")
                if gunAim then
                    local muzzleFlip = gunAim:FindFirstChild("MuzzleFlip")
                    if muzzleFlip then muzzleFlip.Value = 0 end
                end
            end)
            task.wait()
        end
    end)
end

-- No Sway
local swayActive = false
function setNoSway(v)
    if v then
        swayActive = true
        task.spawn(function()
            while swayActive do
                pcall(function()
                    local char = LocalPlayer.Character
                    if char then
                        local gav = char:FindFirstChild("GUNAIMVALUE")
                        if gav then
                            for _, c in ipairs(gav:GetChildren()) do
                                if c:IsA("NumberValue") then c.Value = 0
                                elseif c.Name == "IsAimed" then c.Value = false end
                            end
                        end
                    end
                end)
                task.wait()
            end
        end)
    else
        swayActive = false
    end
end

-- Trigger Bot
local triggerActive = false
local mouseHeld = false
function enableTriggerBot()
    triggerActive = true
    task.spawn(function()
        while triggerActive do
            pcall(function()
                local cam = workspace.CurrentCamera
                if cam and LocalPlayer.Character then
                    local ray = Ray.new(cam.CFrame.Position, cam.CFrame.LookVector * 500)
                    local hit, pos = workspace:FindPartOnRay(ray, LocalPlayer.Character)
                    local found = false
                    if hit then
                        local hum = hit.Parent:FindFirstChildOfClass("Humanoid") or (hit.Parent.Parent and hit.Parent.Parent:FindFirstChildOfClass("Humanoid"))
                        if hum and hum.Health > 0 and hum.Parent ~= LocalPlayer.Character then found = true end
                    end
                    if found and not mouseHeld then
                        VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
                        mouseHeld = true
                    elseif not found and mouseHeld then
                        VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
                        mouseHeld = false
                    end
                end
            end)
            task.wait(0.1)
        end
        if mouseHeld then
            VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
            mouseHeld = false
        end
    end)
end
function disableTriggerBot()
    triggerActive = false
    if mouseHeld then
        VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
        mouseHeld = false
    end
end

-- Infinite Ammo
local infAmmoActive = false
function enableInfiniteAmmo()
    infAmmoActive = true
    task.spawn(function()
        while infAmmoActive do
            pcall(function()
                if LocalPlayer.Character then
                    for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
                        if tool:IsA("Tool") and tool:FindFirstChild("GunScript") then
                            local gs = tool.GunScript
                            local ca = gs:FindFirstChild("ClientAmmo")
                            local maxAmmo = gs:FindFirstChild("MaxAmmo")
                            if ca then ca.Value = maxAmmo and maxAmmo.Value or 30 end
                            local scriptMaxAmmo = tool:FindFirstChild("MaxAmmo")
                            if scriptMaxAmmo then scriptMaxAmmo.Value = 999 end
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end
function disableInfiniteAmmo() infAmmoActive = false end

-- Instant Reload
local instantReloadActive = false
function setInstantReload(v)
    if not v then instantReloadActive = false; return end
    instantReloadActive = true
    task.spawn(function()
        while instantReloadActive do
            pcall(function()
                local char = LocalPlayer.Character
                if not char then return end
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if not humanoid then return end
                for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
                    local animName = track.Animation and track.Animation.Name or ""
                    if animName:lower():find("reload") or animName:lower():find("bolt") then
                        track:AdjustSpeed(10)
                    end
                end
                for _, tool in ipairs(char:GetChildren()) do
                    if tool:IsA("Tool") and tool:FindFirstChild("GunScript") then
                        local gs = tool.GunScript
                        local clientAmmo = gs:FindFirstChild("ClientAmmo")
                        local maxAmmo = gs:FindFirstChild("MaxAmmo")
                        if clientAmmo and maxAmmo and clientAmmo.Value <= 0 then
                            clientAmmo.Value = maxAmmo.Value
                        end
                    end
                end
            end)
            task.wait(0.05)
        end
    end)
end

-- No Spread
local noSpreadActive = false
function setNoSpread(v)
    if not v then noSpreadActive = false; return end
    noSpreadActive = true
    task.spawn(function()
        while noSpreadActive do
            pcall(function()
                local char = LocalPlayer.Character
                if not char then return end
                for _, tool in ipairs(char:GetChildren()) do
                    if tool:IsA("Tool") and tool:FindFirstChild("GunScript") then
                        local gs = tool.GunScript
                        local scatter = gs:FindFirstChild("scatter")
                        if scatter and scatter:IsA("NumberValue") then scatter.Value = 0 end
                        local aimScatter = gs:FindFirstChild("AimScatterMultiplyer")
                        if aimScatter and aimScatter:IsA("NumberValue") then aimScatter.Value = 0 end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end

-- Crosshair
local crosshairGui = nil
function createCrosshair()
    if crosshairGui then return end
    crosshairGui = Instance.new("ScreenGui")
    crosshairGui.Name = "Crosshair"
    crosshairGui.ResetOnSpawn = false
    crosshairGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    local dot = Instance.new("Frame", crosshairGui)
    dot.Size = UDim2.new(0,4,0,4)
    dot.Position = UDim2.new(0.5,-2,0.5,-32)
    dot.BackgroundColor3 = Color3.fromRGB(255,255,255)
    dot.BorderSizePixel = 0
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)
end
function removeCrosshair()
    if crosshairGui then crosshairGui:Destroy(); crosshairGui = nil end
end

-- Wall Check
local function canSeeTarget(part)
    if not Settings.AimbotWallCheck then return true end
    local char = LocalPlayer.Character
    if not char then return true end
    local head = char:FindFirstChild("Head")
    if not head then return true end
    local origin = head.Position
    local dir = (part.Position - head.Position).Unit
    local dist = (part.Position - head.Position).Magnitude
    local ray = Ray.new(origin, dir * dist)
    local hit = workspace:FindPartOnRay(ray, char)
    if hit then return hit:IsDescendantOf(part.Parent) end
    return true
end

-- Get target part
local function getTargetPart(char, partName)
    if partName == "Head" then return char:FindFirstChild("Head")
    elseif partName == "UpperTorso" then return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    elseif partName == "HumanoidRootPart" then return char:FindFirstChild("HumanoidRootPart")
    end
    return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
end

-- Get valid targets
local function getValidTargets(partName)
    local targets = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local part = getTargetPart(plr.Character, partName)
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if part and hum and hum.Health > 0 then
                table.insert(targets, {part = part, hum = hum, player = plr})
            end
        end
    end
    return targets
end

-- Aimbot
local aimbotActive = false
local aimbotConn = nil
function enableAimbot()
    aimbotActive = true
    if aimbotConn then aimbotConn:Disconnect() end
    aimbotConn = RunService.RenderStepped:Connect(function()
        if not aimbotActive then return end
        pcall(function()
            local cam = workspace.CurrentCamera
            if not cam or not LocalPlayer.Character then return end
            local camPos = cam.CFrame.Position
            local camDir = cam.CFrame.LookVector
            local targets = getValidTargets(Settings.AimbotPart)
            if #targets == 0 then return end
            local best = nil
            if Settings.AimbotPriority == "Distance" then
                local bestDist = 99999
                for _, t in ipairs(targets) do
                    if not canSeeTarget(t.part) then continue end
                    local dist = (t.part.Position - camPos).Magnitude
                    local ang = math.deg(math.acos(math.clamp(camDir:Dot((t.part.Position - camPos).Unit), -1, 1)))
                    if ang < Settings.AimbotFOV / 2 and dist < bestDist then bestDist = dist; best = t end
                end
            elseif Settings.AimbotPriority == "FOV" then
                local bestAng = 999
                for _, t in ipairs(targets) do
                    if not canSeeTarget(t.part) then continue end
                    local ang = math.deg(math.acos(math.clamp(camDir:Dot((t.part.Position - camPos).Unit), -1, 1)))
                    if ang < Settings.AimbotFOV / 2 and ang < bestAng then bestAng = ang; best = t end
                end
            elseif Settings.AimbotPriority == "Health" then
                local bestHP = 99999
                for _, t in ipairs(targets) do
                    if not canSeeTarget(t.part) then continue end
                    local ang = math.deg(math.acos(math.clamp(camDir:Dot((t.part.Position - camPos).Unit), -1, 1)))
                    if ang < Settings.AimbotFOV / 2 and t.hum.Health < bestHP then bestHP = t.hum.Health; best = t end
                end
            end
            if best then cam.CFrame = CFrame.new(camPos, best.part.Position) end
        end)
    end)
end
function disableAimbot()
    aimbotActive = false
    if aimbotConn then aimbotConn:Disconnect(); aimbotConn = nil end
end

